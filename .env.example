# PostgreSQL (required on Vercel). Use Neon: https://neon.tech
# Copy the "Direct connection" string from Neon. Do NOT add :443 — Postgres uses 5432 by default.
DATABASE_URL="postgresql://USER:PASSWORD@ep-example.eu-west-2.aws.neon.tech/neondb?sslmode=require"

# Admin bookings page (/admin/login)
ADMIN_PASSWORD="change-this-password"
# Optional extra signing secret. Falls back to ADMIN_PASSWORD if omitted.
ADMIN_SECRET="use-a-long-random-string-in-production"

# Public site URL used in Stripe redirects and emails.
# Local dev: http://localhost:3000
# Production: set to your live domain, e.g. https://wild-hearts-collective.vercel.app
# On Vercel, VERCEL_URL is used automatically if this is omitted.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="Wild Hearts Collective <bookings@wildheartscollective.co.uk>"
STUDIO_EMAIL="hello@wildheartscollective.co.uk"

# Stripe class payments (full amount in advance, pence)
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CLASS_AMOUNT="1000"
# Legacy alias — still supported if STRIPE_CLASS_AMOUNT is unset
STRIPE_DEPOSIT_AMOUNT="1000"

# Monthly membership subscription (pence, default £45)
STRIPE_MEMBERSHIP_PRICE="4500"

# Member sessions (falls back to ADMIN_SECRET / ADMIN_PASSWORD)
MEMBER_SESSION_SECRET=""

# Google OAuth (optional — enables Continue with Google)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Cron jobs (birthday vouchers + engagement automations)
# Call /api/cron/birthday-vouchers and /api/cron/engagement daily with:
# Authorization: Bearer YOUR_CRON_SECRET
CRON_SECRET="use-a-long-random-string"
