generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Class {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String
  description String
  duration    Int       @default(60)
  maxCapacity Int       @default(12)
  sessions    Session[]
  createdAt   DateTime  @default(now())
}

model Tutor {
  id        String    @id @default(cuid())
  name      String
  email     String?
  phone     String?
  active    Boolean   @default(true)
  bio       String?
  sessions  Session[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([active])
}

model Session {
  id             String          @id @default(cuid())
  classId        String
  class          Class           @relation(fields: [classId], references: [id], onDelete: Cascade)
  tutorId        String?
  tutor          Tutor?          @relation(fields: [tutorId], references: [id], onDelete: SetNull)
  startsAt       DateTime
  endsAt         DateTime?
  capacity       Int             @default(12)
  status         String          @default("scheduled")
  adminNotes     String?
  bookings       Booking[]
  waitlist       WaitlistEntry[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([startsAt])
  @@index([classId])
  @@index([tutorId])
  @@index([status])
}

model User {
  id                           String              @id @default(cuid())
  email                        String              @unique
  passwordHash                 String?
  name                         String
  phone                        String?
  image                        String?
  emailVerifiedAt              DateTime?
  phoneVerifiedAt              DateTime?
  dateOfBirth                  DateTime?
  emergencyContactName         String?
  emergencyContactRelationship String?
  emergencyContactPhone        String?
  medicalNotes                 String?
  injuriesLimitations          String?
  allergiesSafetyAlerts        String?
  safetyConsentAt              DateTime?
  parQCompletedAt              DateTime?
  parQData                     Json?
  experienceLevel              String?
  disciplineInterests          String?
  notificationPreferences      String?
  stripeCustomerId             String?             @unique
  membershipPlan               String              @default("account")
  membershipStatus             String              @default("active")
  accountStatus                String              @default("active")
  stripeSubscriptionId         String?             @unique
  membershipStartedAt          DateTime?
  membershipRenewsAt           DateTime?
  membershipPausedAt           DateTime?
  membershipResumeAt           DateTime?
  membershipCancelledAt        DateTime?
  cancellationReason           String?
  creditsRemaining             Int                 @default(0)
  totalClassesAttended         Int                 @default(0)
  lastClassAttendedAt          DateTime?
  milestonesAwarded            Json?
  internalNotes                String?
  createdAt                    DateTime            @default(now())
  updatedAt                    DateTime            @updatedAt
  bookings                     Booking[]
  waitlist                     WaitlistEntry[]
  oauthAccounts                OAuthAccount[]
  verificationCodes            VerificationCode[]
  membershipEvents             MembershipEvent[]
  auditLogs                    AdminAuditLog[]     @relation("AuditTarget")
  classPackPurchases           ClassPackPurchase[]
  creditTransactions           CreditTransaction[]
  vouchers                     Voucher[]
  parQResponse                 ParQResponse?
  engagementLogs               EngagementLog[]

  @@index([email])
  @@index([membershipStatus])
  @@index([accountStatus])
  @@index([experienceLevel])
  @@index([dateOfBirth])
  @@index([lastClassAttendedAt])
}

model OAuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  profileImageUrl   String?
  createdAt         DateTime @default(now())

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model VerificationCode {
  id        String    @id @default(cuid())
  userId    String?
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  email     String?
  phone     String?
  codeHash  String
  purpose   String
  channel   String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([email, purpose])
  @@index([userId, purpose])
}

model MembershipEvent {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        String
  note        String?
  effectiveAt DateTime
  endsAt      DateTime?
  createdBy   String    @default("member")
  createdAt   DateTime  @default(now())

  @@index([userId, effectiveAt])
}

model AdminAuditLog {
  id           String   @id @default(cuid())
  action       String
  targetUserId String?
  targetUser   User?    @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)
  adminLabel   String   @default("admin")
  details      String?
  createdAt    DateTime @default(now())

  @@index([targetUserId])
  @@index([createdAt])
}

model ClassPack {
  id          String              @id @default(cuid())
  slug        String              @unique
  name        String
  description String?
  credits     Int
  pricePence  Int
  validDays   Int                 @default(90)
  active      Boolean             @default(true)
  sortOrder   Int                 @default(0)
  createdAt   DateTime            @default(now())
  purchases   ClassPackPurchase[]
}

model ClassPackPurchase {
  id                 String              @id @default(cuid())
  userId             String
  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  packId             String
  pack               ClassPack           @relation(fields: [packId], references: [id], onDelete: Restrict)
  creditsGranted     Int
  creditsRemaining   Int
  expiresAt          DateTime
  stripeSessionId    String?             @unique
  stripePaymentId    String?
  status             String              @default("active")
  giftCardId         String?
  giftCard           GiftCard?           @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  giftAmountApplied  Int?
  createdAt          DateTime            @default(now())
  bookings           Booking[]
  creditTransactions CreditTransaction[]
  giftRedemptions    GiftCardRedemption[]

  @@index([userId])
  @@index([status])
  @@index([expiresAt])
  @@index([giftCardId])
}

model CreditTransaction {
  id           String             @id @default(cuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  purchaseId   String?
  purchase     ClassPackPurchase? @relation(fields: [purchaseId], references: [id], onDelete: SetNull)
  bookingId    String?
  booking      Booking?           @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  amount       Int
  balanceAfter Int
  reason       String
  createdAt    DateTime           @default(now())

  @@index([userId, createdAt])
  @@index([bookingId])
}

model Voucher {
  id              String    @id @default(cuid())
  code            String    @unique
  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  type            String
  discountPercent Int       @default(100)
  expiresAt       DateTime
  usedAt          DateTime?
  bookingId       String?   @unique
  booking         Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  metadata        Json?
  createdAt       DateTime  @default(now())

  @@index([userId])
  @@index([type])
  @@index([expiresAt])
}

/**
 * Shop checkout ledger — one row per paid Stripe session.
 * Covers gift vouchers today and physical / other catalog items later.
 */
model ShopOrder {
  id               String          @id @default(cuid())
  stripeSessionId  String          @unique
  status           String          @default("paid")
  /** e.g. shop_voucher | shop_product */
  sourceType       String          @default("shop_voucher")
  purchaserEmail   String?
  purchaserName    String?
  totalPence       Int
  currency         String          @default("gbp")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  items            ShopOrderItem[]

  @@index([createdAt])
  @@index([purchaserEmail])
  @@index([status])
}

model ShopOrderItem {
  id               String       @id @default(cuid())
  orderId          String
  order            ShopOrder    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId        String?
  product          ShopProduct? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName      String
  productSlug      String?
  category         String?
  quantity         Int       @default(1)
  unitPricePence   Int
  lineTotalPence   Int
  /** gift_card | physical | digital */
  fulfillmentType  String    @default("gift_card")
  giftCardId       String?
  createdAt        DateTime  @default(now())

  @@index([orderId])
  @@index([productId])
  @@index([giftCardId])
}

/** Client-managed shop catalog — editable in admin. */
model ShopProduct {
  id              String           @id @default(cuid())
  slug            String           @unique
  name            String
  description     String
  category        String
  pricePence      Int
  isAvailable     Boolean          @default(false)
  digitalDelivery Boolean          @default(false)
  image           String
  imageGradient   String           @default("from-pink-soft via-cream to-sage-light")
  variants        Json?
  sortOrder       Int              @default(0)
  isArchived      Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  orderItems      ShopOrderItem[]

  @@index([category])
  @@index([isAvailable, isArchived])
  @@index([sortOrder])
  @@index([createdAt])
}

/** Monetised shop e-gift cards with a remaining balance in pence. */
model GiftCard {
  id                  String              @id @default(cuid())
  code                String              @unique
  initialBalancePence Int
  balancePence        Int
  productId           String?
  productName         String
  purchaserEmail      String?
  purchaserName       String?
  stripeSessionId     String?
  expiresAt           DateTime?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt
  redemptions         GiftCardRedemption[]
  bookings            Booking[]
  packPurchases       ClassPackPurchase[]

  @@index([stripeSessionId])
  @@index([balancePence])
  @@index([expiresAt])
}

model GiftCardRedemption {
  id             String            @id @default(cuid())
  giftCardId     String
  giftCard       GiftCard          @relation(fields: [giftCardId], references: [id], onDelete: Cascade)
  amountPence    Int
  balanceAfter   Int
  reason         String
  bookingId      String?
  booking        Booking?          @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  packPurchaseId String?
  packPurchase   ClassPackPurchase? @relation(fields: [packPurchaseId], references: [id], onDelete: SetNull)
  userId         String?
  createdAt      DateTime          @default(now())

  @@index([giftCardId, createdAt])
  @@index([bookingId])
  @@index([packPurchaseId])
}

model ParQResponse {
  id          String   @id @default(cuid())
  userId      String   @unique
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  data        Json
  submittedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EngagementLog {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  status    String    @default("pending")
  metadata  Json?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, type])
  @@index([status, createdAt])
}

model Booking {
  id               String              @id @default(cuid())
  sessionId        String
  session          Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId           String?
  user             User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  name             String
  email            String
  phone            String?
  notes            String?
  status           String              @default("pending")
  attendance       String?
  cancellationType String?
  paidWithCredit   Boolean             @default(false)
  packPurchaseId   String?
  packPurchase     ClassPackPurchase?  @relation(fields: [packPurchaseId], references: [id], onDelete: SetNull)
  voucherId        String?
  voucher          Voucher?
  giftCardId       String?
  giftCard         GiftCard?           @relation(fields: [giftCardId], references: [id], onDelete: SetNull)
  giftAmountApplied Int?
  stripeSessionId  String?             @unique
  stripePaymentId  String?
  amountPaid       Int?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @default(now()) @updatedAt
  creditTransactions CreditTransaction[]
  giftRedemptions  GiftCardRedemption[]

  @@index([sessionId])
  @@index([email])
  @@index([userId])
  @@index([status])
  @@index([attendance])
  @@index([giftCardId])
}

model WaitlistEntry {
  id        String   @id @default(cuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  name      String
  email     String
  phone     String?
  notes     String?
  status    String   @default("waiting")
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([sessionId])
  @@index([email])
  @@index([userId])
  @@index([status])
}
